datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Job {
  id        String   @id @default(uuid())
  prompt    String
  status    String   @default("queued")
  progress  Int      @default(0)
  createdAt DateTime @default(now())
}
